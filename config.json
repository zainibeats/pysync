{
    "settings": {
        "mount_all_before_sync": false
    },

    "sources": [
        {
            "name": "testnfs1",
            "path": "~/remote_mount/testnfs1/",
            "type": "nfs",
            "mount_point": "~/remote_mount/testnfs1"
        },

        {
            "name": "testnfs3",
            "path": "~/remote_mount/testnfs3/",
            "type": "nfs",
            "mount_point": "~/remote_mount/testnfs3"
        } 

    ],

    "destinations": [
        {
            "name": "test-dest-1",
            "path": "~/Documents/test-dir/dest-1",
            "type": "local",
            "mount_point": null
        },
        {
            "name": "test-dest-2",
            "path": "~/Documents/test-dir/dest-2",
            "type": "local",
            "mount_point": null
        },
        {
            "name": "testnfs2",
            "path": "~/remote_mount/testnfs2/",
            "type": "nfs",
            "mount_point": "~/remote_mount/testnfs2"
        }
    ],

    "jobs": [
        {
            "name": "Test backup",
            "source": "testnfs1",
            "destination": "testnfs2",
            "exclude_from": null,
            "flags": ["-av", "--delete"]
        },
        {
            "name": "Test backup 2",
            "source": "testnfs3",
            "destination": "test-dest-2",
            "exclude_from": null,
            "flags": ["-av", "--delete"]
        }        
    ]
}
